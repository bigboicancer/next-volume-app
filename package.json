{
  "name": "next-volume",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web && workbox generateSW workbox-config.cjs",
    "serve:web": "expo serve",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx scripts/catalog-smoke.ts",
    "check": "npm run typecheck && npm run test"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.36",
    "expo-font": "~14.0.12",
    "expo-linear-gradient": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "~0.21.0",
    "@expo/metro-runtime": "~6.1.2"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "tsx": "^4.23.1",
    "typescript": "~5.9.2",
    "workbox-cli": "^7.4.1"
  }
}
